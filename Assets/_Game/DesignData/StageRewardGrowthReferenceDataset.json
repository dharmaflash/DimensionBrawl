  "firstStageLoop": [
    {
      "beat": 1,
      "screen": "Lobby",
      "playerSees": "guide character, current energy, next stage",
      "dataRowsNeeded": [
        "LobbyGuideFeedback",
        "DailyRoutineTask"
      ],
      "note": "Reuse UI cue research; no full base yet."
    },
    {
      "beat": 2,
      "screen": "StageSelect",
      "playerSees": "boss threat, reward, recommended summon need",
      "dataRowsNeeded": [
        "StageProgressionNode",
        "RunRewardPlan",
        "BossPatternDeck"
      ],
      "note": "Show Break/Tank/Arrow/Heal need, not long text."
    },
    {
      "beat": 3,
      "screen": "Prep",
      "playerSees": "current summon queue, one tactical hint",
      "dataRowsNeeded": [
        "StageEntryCue",
        "SummonLoadoutHint"
      ],
      "note": "No hand-of-cards return."
    },
    {
      "beat": 4,
      "screen": "Combat",
      "playerSees": "3 to 5 minute horizontal ARPG Story PvE run",
      "dataRowsNeeded": [
        "BossRunDefinition",
        "EncounterPressurePlan"
      ],
      "note": "Existing boss/run research owns this."
    },
    {
      "beat": 5,
      "screen": "Result",
      "playerSees": "rank, action proof, rewards",
      "dataRowsNeeded": [
        "RunResultSummary",
        "RewardRevealCue"
      ],
      "note": "Reward reveal should be skippable."
    },
    {
      "beat": 6,
      "screen": "Growth",
      "playerSees": "one recommended upgrade",
      "dataRowsNeeded": [
        "GrowthSink",
        "CurrencyBalance"
      ],
      "note": "Show one next improvement, not a huge menu."
    },
    {
      "beat": 7,
      "screen": "Next",
      "playerSees": "retry, next stage, or guide task",
      "dataRowsNeeded": [
        "NextActionRecommendation"
      ],
      "note": "Instant retry remains visible."
    }
  ],
