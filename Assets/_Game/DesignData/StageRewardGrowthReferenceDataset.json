  "observedLoopShapes": [
    {
      "id": "reward_claim_resource_not_retry_tax",
      "sources": [
        "zzz_battery_charge",
        "pgr_serum",
        "genshin_hsr_reward_claim",
        "arknights_sanity_riic"
      ],
      "insight": "Major gacha/action RPGs protect reward pacing with stamina-like resources while allowing retry or reward-claim separation. This is especially important for action games where learning a fight must not feel expensive.",
      "isekaiBrawlUse": "Keep immediate retry free. If a stamina-like system appears later, spend it on result reward claim, not on failed learning attempts."
    },
    {
      "id": "account_rank_bundles_cap_difficulty_reward",
      "sources": [
        "zzz_inter_knot",
        "pgr_beginner_unlocks"
      ],
      "insight": "Account progression bundles character/summon cap increases, new difficulty rows, and reward tier increases behind readiness checks.",
      "isekaiBrawlUse": "Later account rank should unlock run tier, summon role cap, and boss deck modifier together after a short readiness run."
    },
    {
      "id": "story_milestones_unlock_systems",
      "sources": [
        "pgr_beginner_unlocks",
        "blue_archive_campaign_farm"
      ],
      "insight": "New players see systems in slices as story stages are cleared. This keeps the first-session burden low while still giving long-term structure.",
      "isekaiBrawlUse": "Unlock StageSelect/Result first, then SummonUpgrade, DailyPractice, and BossDrill only after each combat lesson is taught."
    },
    {
      "id": "daily_tasks_are_behavior_routes",
      "sources": [
        "hi3_missions",
        "hi3_data_loop_tables",
        "wuwa_guidebook_waveplate"
      ],
      "insight": "Daily task rows route players into specific behaviors and screens, carry deep-link data, and feed threshold reward tracks.",
      "isekaiBrawlUse": "Daily tasks should be combat lesson tasks: perfect dodge, Tank rescue, Break structure, Arrow backline, Heal under pressure."
    },
    {
      "id": "guidebook_as_action_router",
      "sources": [
        "wuwa_guidebook_waveplate",
        "genshin_hsr_reward_claim"
      ],
      "insight": "A guidebook can unify daily activity, material routing, training, milestones, recurring challenges, and enemy tracing.",
      "isekaiBrawlUse": "Create a compact Tactical Guide later with Today, Growth, Boss Drill, Summon Role Practice, and Enemy Trace tabs."
    },
    {
      "id": "mastery_unlocks_convenience",
      "sources": [
        "blue_archive_campaign_farm"
      ],
      "insight": "Clear quality such as 3-star completion can unlock sweep/quick clear without replacing the initial combat experience.",
      "isekaiBrawlUse": "Use mastery objectives to unlock quick replay/simulated clear only after the player proves the intended combat answers."
    },
    {
      "id": "score_modes_separate_practice_and_submission",
      "sources": [
        "pgr_score_modes"
      ],
      "insight": "Score modes can allow unlimited or protected practice while controlling official attempts or final score submission.",
      "isekaiBrawlUse": "Boss Drill should be practice-friendly. Result score should initially be local proof, not competitive ranking."
    },
    {
      "id": "passive_base_rewards_are_long_tail_not_v1_core",
      "sources": [
        "pgr_dorm",
        "nikke_outpost",
        "arknights_sanity_riic"
      ],
      "insight": "Dorm/base/outpost systems can deepen retention and character attachment, but they become their own management game if introduced too early.",
      "isekaiBrawlUse": "Delay full base management. Prepare only a small Summon Camp concept for passive low-value materials and role training later."
    }
  ],
