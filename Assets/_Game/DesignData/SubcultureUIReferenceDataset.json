  "isekaiBrawlDirection": {
    "title": "Full-screen world/hero/summon presentation, one clear start prompt, minimal utility, BGM fade into lobby.",
    "lobby": "Emotional home with one guide heroine or summon signboard; Story PvE is the main CTA; secondary features stay compact.",
    "stageSelect": "Expose current run target, boss/threat, reward, and recommended summon role; retry path should skip ceremony.",
    "inGameHud": "Landscape ARPG HUD may explore new placement but must not revive 5-card hand, lane-first input, or direct target selection.",
    "result": "Victory reveals outcome/rank/reward/progression; failure prioritizes cause and instant retry."
  }
