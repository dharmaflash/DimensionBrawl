  "scenePatterns": [
    {
      "id": "title_ambient_start",
      "scene": "login",
      "purpose": "Brand promise, account/server/status entry, first BGM and first interaction.",
      "layers": ["full_bleed_background_or_3d_shot", "logo", "start_prompt", "server_account_version", "tiny_utility_buttons"],
      "cueRecipe": {
        "motion": "slow ambient background, prompt pulse",
        "sfx": ["soft_start_prompt_loop_optional", "tap_confirm"],
        "vfx": ["logo_glint_optional", "fade_overlay"],
        "bgm": "Title context, crossfade to Lobby"
      },
      "isekaiBrawlUse": "Quiet full-bleed title selling horizontal ARPG plus summon-first fantasy."
    },
    {
      "id": "login_patch_loading_deck",
      "scene": "login_loading",
      "purpose": "Mask resource loading while teaching world/combat/summon hints.",
      "layers": ["loading_art", "title", "description", "progress_bar", "resource_status"],
      "cueRecipe": {
        "motion": "fade between weighted cards",
        "sfx": ["subtle_progress_tick_optional"],
        "vfx": ["light_noise", "card_fade"],
        "bgm": "Title or neutral loading loop"
      },
      "isekaiBrawlUse": "Weighted loading cards for boss pressure, summon roles, and story PvE flavor."
    },
    {
      "id": "lobby_character_signboard",
      "scene": "lobby",
      "purpose": "Daily emotional home and conditional character response.",
      "layers": ["character_or_summon", "top_status", "main_cta", "feature_rail", "conditional_line"],
      "cueRecipe": {
        "motion": "idle, greet, tap, reward, warning",
        "sfx": ["tiny_tap", "soft_panel_open", "voice_optional"],
        "vfx": ["small_attention_glow", "reward_sparkle_optional"],
        "bgm": "Lobby loop"
      },
      "isekaiBrawlUse": "One guide heroine or summon reacts to return, reward, summon ready, and failed retry."
    },
    {
      "id": "lobby_primary_cta_anchor",
      "scene": "lobby",
      "purpose": "Keep the main play route visible above event clutter.",
      "layers": ["main_story_button", "event_banner", "secondary_feature_rail", "currency_strip"],
      "cueRecipe": {
        "motion": "main CTA idle emphasis lower than event animation",
        "sfx": ["confirm_start", "tab_switch"],
        "vfx": ["main_cta_glint_on_return"],
        "bgm": "Lobby loop"
      },
      "isekaiBrawlUse": "Story PvE remains the strongest route from lobby."
    },
    {
      "id": "stage_card_expand",
      "scene": "stage_select",
      "purpose": "Turn intent into a clear run.",
      "layers": ["map_or_stage_list", "stage_card", "threat_tags", "reward_preview", "start_button"],
      "cueRecipe": {
        "motion": "card expand, reward glint, map pan optional",
        "sfx": ["stage_select", "start_confirm"],
        "vfx": ["threat_tag_flash", "reward_sparkle"],
        "bgm": "StageSelect context"
      },
      "isekaiBrawlUse": "Expose boss threat and recommended summon role without card-hand language."
    },
    {
      "id": "stage_to_combat_mood_bridge",
      "scene": "stage_select_to_combat",
      "purpose": "Carry selected stage mood into combat start.",
      "layers": ["fade_overlay", "loading_card_optional", "combat_intro_banner"],
      "cueRecipe": {
        "motion": "fade and push",
        "sfx": ["confirm_start", "combat_ready"],
        "vfx": ["stage_color_tint", "short_screen_flash"],
        "bgm": "StageSelect to Combat crossfade"
      },
      "isekaiBrawlUse": "Selected boss/stage mood should not reset abruptly at combat load."
    },
    {
      "id": "combat_start_banner",
      "scene": "in_game",
      "purpose": "Announce encounter without blocking control too long.",
      "layers": ["top_banner", "objective", "camera_settle", "control_visibility"],
      "cueRecipe": {
        "motion": "banner in/out 0.40-0.90s",
        "sfx": ["combat_start"],
        "vfx": ["thin_scanline_or_slash_optional"],
        "bgm": "Combat loop"
      },
      "isekaiBrawlUse": "Short encounter intro compatible with immediate movement."
    },
    {
      "id": "perfect_dodge_feedback_bundle",
      "scene": "in_game_hud",
      "purpose": "Make perfect dodge readable and rewarding without adding parry complexity.",
      "layers": ["edge_flash", "dodge_button_pulse", "time_slow_tint", "camera_cue"],
      "cueRecipe": {
        "motion": "0.18-0.40s flash and cleanup",
        "sfx": ["dodge_success", "counter_window_open"],
        "vfx": ["afterimage", "time_slow_edge"],
        "bgm": "duck or sidechain optional, not mandatory"
      },
      "isekaiBrawlUse": "Primary read-react payoff cue for current player-feel baseline."
    },
    {
      "id": "summon_call_primary_pulse",
      "scene": "in_game_hud",
      "purpose": "Make one-slot summon call feel like the identity action.",
      "layers": ["summon_button", "summon_card_shine", "entry_vfx", "camera_cue"],
      "cueRecipe": {
        "motion": "0.25-0.60s button pulse",
        "sfx": ["summon_call", "assist_entry"],
        "vfx": ["card_aura", "spawn_flash", "impact_optional"],
        "bgm": "no full BGM interruption"
      },
      "isekaiBrawlUse": "Highest-priority combat UI identity cue."
    },
    {
      "id": "ultimate_ready_sting",
      "scene": "in_game_hud",
      "purpose": "Signal readiness strongly once, then stay calm.",
      "layers": ["ultimate_button", "resource_bar", "edge_glow_optional"],
      "cueRecipe": {
        "motion": "0.35-0.70s flare",
        "sfx": ["ultimate_ready_sting"],
        "vfx": ["button_flare"],
        "bgm": "none"
      },
      "isekaiBrawlUse": "Avoid noisy looping ultimate-ready effects."
    },
    {
      "id": "objective_toast_compact",
      "scene": "in_game_hud",
      "purpose": "Communicate state changes without a verbose combat log.",
      "layers": ["top_band", "icon", "one_line_text"],
      "cueRecipe": {
        "motion": "short slide/fade",
        "sfx": ["objective_update"],
        "vfx": ["thin_highlight"],
        "bgm": "none"
      },
      "isekaiBrawlUse": "Top-band oracle hint stays compact."
    },
    {
      "id": "result_rank_reward_sequence",
      "scene": "result",
      "purpose": "Close the run with outcome, rank, reward, progression, and next action.",
      "layers": ["outcome_title", "rank", "reward_cards", "progression", "next_buttons"],
      "cueRecipe": {
        "motion": "layered reveal, skip allowed",
        "sfx": ["result_title", "rank_stamp", "reward_tick"],
        "vfx": ["rank_flash", "reward_sparkle"],
        "bgm": "ResultWin or ResultFail"
      },
      "isekaiBrawlUse": "Victory can breathe; failure prioritizes instant retry."
    },
    {
      "id": "denied_action_micro_toast",
      "scene": "any",
      "purpose": "Explain a blocked action without opening a panel.",
      "layers": ["button_pulse", "short_text", "tiny_icon"],
      "cueRecipe": {
        "motion": "0.12-0.25s shake or pulse",
        "sfx": ["denied_soft"],
        "vfx": ["amber_or_red_flash"],
        "bgm": "none"
      },
      "isekaiBrawlUse": "Use for cooldown, not enough energy, cannot summon."
    }
  ],
