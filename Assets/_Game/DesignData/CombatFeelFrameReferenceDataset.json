      "manual_basic_attack_mash_as_core",
      "many_active_attack_buttons",
      "baseline_parry_button",
      "full_party_switching",
      "hard_target_selection_ui",
      "long_execution_combo_strings"
    ],
    "assetReuseBoundary": "Do not import proprietary animation clips, full source files, raw tables, meshes, textures, or audio. Extract schemas, timing ranges, field relationships, and authoring ideas."
