  "observedDataShapes": [
    {
      "id": "zzz_attack_state_camera",
      "sourceId": "zzz_data_combo",
      "fields": ["AnimatorStateName", "NormalizedTimeLow", "NormalizedTimeHigh", "ModifierNameList", "CameraEventModifier"],
      "insight": "Basic attack chains can be split into start, loop, directional, and end states, each with camera modifiers.",
      "isekaiBrawlUse": "Split auto basic fire into visible beat states while keeping input simple."
    },
    {
      "id": "zzz_perfect_combo_counter",
      "sourceId": "zzz_data_combo",
      "fields": ["AS_PerfectComboIndex", "PerfectComboModifier_Count", "PerfectComboModifier_Reset", "Bool_PerfectCombo", "Duration"],
      "insight": "Perfect combo can be counted/reset through animation-state entry and a short modifier window.",
      "isekaiBrawlUse": "Use a 0.6-1.2s grace window for perfect-dodge follow-up state."
    },
    {
      "id": "zzz_witch_time_reward",
      "sourceId": "zzz_data_combo",
      "fields": ["OnDodgeSuccess", "DurationTime", "WitchSlowDownMixin", "OnRemoved", "TriggerSoundAction"],
      "insight": "Perfect dodge reward can be a timed state with slow-down, team modifiers, cleanup, and sound hooks.",
      "isekaiBrawlUse": "Author perfect dodge as brief slow plus empowered basic-fire pressure, with explicit cleanup."
    },
    {
      "id": "zzz_attack_sfx_vfx_hooks",
      "sourceId": "zzz_data_combo",
      "fields": ["ByAnimEventIDs", "FireAudio", "AudioPattern", "AttachEffect", "EffectPattern", "AttachPoint"],
      "insight": "SFX/VFX can be bound to animation and hit events, not only input events.",
      "isekaiBrawlUse": "Use ComboCueBundle for hits, summon entries, and ultimate impacts."
    },
    {
      "id": "pgr_animator_action_taxonomy",
      "sourceId": "pgr_data_fight",
      "fields": ["Id", "Name", "IsTrigger"],
      "insight": "Combat action taxonomy separates trigger actions from continuous states and includes many attack slots plus hit/stagger states.",
      "isekaiBrawlUse": "Define ComboActionState with trigger/state distinction."
    },
    {
      "id": "pgr_screen_role_effect_split",
      "sourceId": "pgr_data_fight",
      "fields": ["RoleEffect", "ScreenEffect", "Type", "Intensity", "FadeIn", "FadeOut", "PlayAlone"],
      "insight": "Actor and screen effects are separate data layers.",
      "isekaiBrawlUse": "Keep ActorEffectCue and ScreenEffectCue separate in future combat polish data."
    },
    {
      "id": "hi3_attack_speed_skill_split",
      "sourceId": "hi3_data_skills",
      "fields": ["AvatarID", "IsFixAttackSpeed", "K1-K12", "buttonName", "iconPath", "skillId", "avatarSubSkillId", "paramBase", "paramAdd"],
      "insight": "Attack speed, button identity, skill data, and subskill data are separate.",
      "isekaiBrawlUse": "Do not hardwire animation speed, button UI, and damage tuning into one class."
    },
    {
      "id": "hi3_attack_punish_curve",
      "sourceId": "hi3_data_skills",
      "fields": ["LevelDifference", "DamageReduceRate"],
      "insight": "Combat output can be clamped through separate punish curves.",
      "isekaiBrawlUse": "Keep future combo reward scaling separate from action timing."
    }
  ],
  "mechanicFindings": [
    {
      "id": "basic_sequence_cancel_hierarchy",
      "sources": ["hi3_wiki_combat", "genshin_wiki_normal_attack", "zzz_wiki_basic_attack"],
      "finding": "Basic attacks are often sequence-based but remain cancellable by survival or high-priority verbs.",
      "isekaiBrawlUse": "Auto basic fire should never block dodge, summon, or ultimate."
    },
    {
      "id": "hold_branch_as_optional_expression",
      "sources": ["hi3_wiki_combat", "zzz_wiki_special_attack", "genshin_wiki_normal_attack"],
      "finding": "Hold inputs create charge/branch/heavy routes but add input complexity.",
      "isekaiBrawlUse": "Do not add a hold attack by default; consider only after core controls are stable."
    },
    {
      "id": "dodge_counter_as_main_payoff",
      "sources": ["zzz_wiki_dodge", "wuwa_wiki_combat", "zzz_data_combo"],
      "finding": "Perfect dodge often opens a direct counter or empowered attack route with invulnerability/readability.",
      "isekaiBrawlUse": "Primary combo payoff should be perfect dodge into empowered basic-fire pressure."
    },
    {
      "id": "assist_qte_as_summon_model",
      "sources": ["zzz_wiki_assist", "pgr_wiki_combat_guide", "wuwa_wiki_combat"],
      "finding": "Assist/QTE/Intro systems can add a high-impact ally action without full control handoff.",
      "isekaiBrawlUse": "Summon call should read like assist entry, not just spawned pet logic."
    },
    {
      "id": "break_chain_state",
      "sources": ["zzz_wiki_chain_attack", "wuwa_wiki_combat", "pgr_wiki_combat_guide"],
      "finding": "Break/daze/shield states can open high-value follow-up windows.",
      "isekaiBrawlUse": "BossPatternBreak should open a short summon-first follow-up window."
    },
    {
      "id": "temporary_empowered_basic",
      "sources": ["hi3_wiki_combat", "zzz_data_combo", "pgr_wiki_combat_guide"],
      "finding": "Burst/Matrix/WitchTime-like states temporarily transform normal actions.",
      "isekaiBrawlUse": "Use short empowered sword-wave after perfect dodge, not a permanent bigger projectile."
    }
  ],
